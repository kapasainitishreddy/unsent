# --- Server ---
PORT=4000
HOST=127.0.0.1
DB_PATH=./data/unsent.db

# --- AI companion ---
# Pick ONE provider. Order of priority (highest first):
#   1. UNSENT_LLM_BASE - any OpenAI-compatible endpoint
#   2. NINE_ROUTER_URL - local 9router (free, 40+ providers, auto-fallback)
#   3. OPENROUTER_API_KEY - OpenRouter cloud
#   4. GROQ_API_KEY - Groq cloud
# If none set: runs in MOCK mode (canned, but real crisis detection)

# Option 1: 9router (recommended for free unlimited AI)
# Get it: https://github.com/decolua/9router
# Run: npx 9router, default URL is http://127.0.0.1:9545/v1
NINE_ROUTER_URL=
NINE_ROUTER_MODEL=auto
NINE_ROUTER_KEY=

# Option 2: OpenRouter free tier
# Get a key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
UNSENT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Option 3: Groq free tier
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Option 4: any custom OpenAI-compatible endpoint
UNSENT_LLM_BASE=
UNSENT_LLM_KEY=
UNSENT_LLM_MODEL=

# --- Auth (Clerk) ---
# Get these at https://dashboard.clerk.com -> API Keys
# Leave BOTH BLANK to run in dev mode (single local_user, no real auth).
# If CLERK_SECRET_KEY is set, all /api/* routes require a valid Clerk session
# token in the Authorization: Bearer header. Without it, all requests authenticate
# as a single local_user for development.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Optional: restrict to a specific Clerk instance/frontend URL
CLERK_FRONTEND_URL=http://localhost:3000

# --- In-app purchases (RevenueCat) ---
# The public SDK key is set in the mobile app (capacitor.config.json or build env),
# NOT here - only the webhook secret lives server-side.
# Configure in RevenueCat dashboard: Project -> Integrations -> Webhooks -> Authorization header
# Leave BLANK to accept webhooks from anyone (NOT recommended for production).
REVENUECAT_WEBHOOK_SECRET=
# Server-side REST API key for verifying entitlements (optional, RC_GET_CUSTOMER_INFO)
REVENUECAT_API_KEY=
