# --- Server ---
PORT=4000
HOST=127.0.0.1
DB_PATH=./data/unsent.db

# --- AI companion (OpenRouter free tier; $0) ---
# Get a free key at https://openrouter.ai/keys
# Free models that work: meta-llama/llama-3.3-70b-instruct:free,
# qwen/qwen-2.5-72b-instruct:free, google/gemini-2.0-flash-exp:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# Optional: Groq (also has free tier, faster)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Auth (Clerk) ---
# Get these at https://dashboard.clerk.com → API Keys
# Leave both BLANK to run in dev mode (single 'local_user', no real auth).
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
# Optional: restrict to a specific Clerk instance/frontend URL
CLERK_FRONTEND_URL=http://localhost:3000

# --- Privacy ---
# All data is local. No telemetry. No analytics.
